FROM golang:1.24-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /bayed-client ./cmd/bayed-client/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /bayed-client /usr/local/bin/bayed-client
ENTRYPOINT ["bayed-client"]
