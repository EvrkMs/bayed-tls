FROM golang:1.24-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /bayed-server ./cmd/bayed-server/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /bayed-server /usr/local/bin/bayed-server
EXPOSE 443
ENTRYPOINT ["bayed-server"]
